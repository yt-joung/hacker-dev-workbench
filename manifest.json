{
  "manifest_version": 3,
  "name": "HackerDev Workbench",
  "version": "1.0.0",
  "description": "Chrome DevTools for Hackers - Semi-Auto Workbench",
  "permissions": [
    "sidePanel",
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open HackerDev Workbench",
    "default_icon": "favicon.svg"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/hook.ts"],
      "matches": ["<all_urls>"]
    }
  ]
}
